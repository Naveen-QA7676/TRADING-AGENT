# ============================================================
# AI INSTITUTIONAL TRADING INTELLIGENCE PLATFORM — ENV CONFIG
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Zerodha Kite Connect ---
KITE_API_KEY=your_kite_api_key_here
KITE_SECRET=your_kite_secret_here
KITE_USER_ID=your_zerodha_user_id
KITE_ACCESS_TOKEN=            # auto-populated after daily login

# --- AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Web Research ---
SERPAPI_KEY=your_serpapi_key_here
NEWS_API_KEY=your_newsapi_key_here

# --- Database ---
DATABASE_URL=postgresql://trading_user:password@localhost:5432/trading_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App Config ---
SECRET_KEY=generate_a_long_random_secret_key_here
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO

# --- Trading Config ---
CAPITAL=150000                 # Your trading capital in INR
MAX_RISK_PER_TRADE=0.01        # 1% max risk per trade
MAX_DAILY_LOSS=0.02            # 2% daily loss limit
MAX_WEEKLY_LOSS=0.05           # 5% weekly loss limit
MAX_OPEN_POSITIONS=3
MIN_CONFIDENCE_SCORE=70        # Minimum score to trigger suggestion
SQUAREOFF_TIME=15:25           # Auto square-off time IST
NO_TRADE_BUFFER_MINUTES=5      # No trades in first 5 min (9:15–9:20)
